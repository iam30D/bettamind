---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <slot name="actions" />
      <slot />
    </div>
  </div>
</section>
